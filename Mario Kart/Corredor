import java.util.ArrayList;
import java.util.List;
public class Corredor{
    private String nombre;
    private int velocidad,peso,capacidaddedrift;
    static List <Corredor> corredores = new ArrayList<>();
    public Corredor(String nombre, int velocidad, int peso, int capacidaddedrift) {
        this.nombre=nombre;
        this.velocidad=velocidad;
        this.peso=peso;
        this.capacidaddedrift=capacidaddedrift;
    }
    public static void InicializarCorredores()
    {
        corredores.add(new Corredor("Mario",40,3,1));
        corredores.add(new Corredor("Rammus",60,8,0));
        corredores.add(new Corredor("Franklin Clinton",50,6,4));
        corredores.add(new Corredor("Nunu y Willump",70,12,-4));
        corredores.add(new Corredor("Caracol Turbo",1,0,20));
    }

    public String getNombre() {
        return nombre;
    }

    public static void MostrarCorredores()
    {
        for (int i=0;i<corredores.size();i++)
        {
            System.out.print(i+1+")");
            System.out.println(MostrarCorredor(corredores.get(i)));
        }
    }
    public static String MostrarCorredor(Corredor x){
        return " Nombre: "+x.nombre+
                " Velocidad: "+x.velocidad+
                " Peso: "+x.peso+
                " Habilidad de Drift: "+x.capacidaddedrift;
    }
}
