import java.nio.channels.SelectableChannel;

public class Main{
    public static void main(String[] args)
    {
        Menu();
        SeleccionarCorredr();
    }
    static void Menu() {
        System.out.println("------/MARIO KART 2\\------" +
                "(No aprobado por Nintendo)");
    }
    static void SeleccionarCorredr()
    {
        System.out.println("Seleccione a su corredor");
        Corredor.MostrarCorredores();
    }
}
3 hilos corredores 

main
elejir corredor--->
crear vehiculo ---> vehiculo class
				->Auto
				->Moto
tipo de carrera->aleatorio ->Random runners
	       ->clasico   ->picked runners ->Lista de corredores -> corredores class
									->String nombre
									->int Peso        //el peso determina la velocidad, cad apunto de peso dse resta 3m/s a la Velocidad del corredor
									->int Drift	  //cada 1s FuncionBoost()->por cada punto extra a 10, 5% de boost (avanza 10m)
									->int Estabilidad //cada 1s FuncionCaerse()->por cada punto menor a 10, 5% de caerse (caerse atrasa 5m)
elejir mapa (entre 3 ) -> mapa class
				->int CantVueltas

