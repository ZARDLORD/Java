import java.util.Scanner;

public class Util {
    static Scanner read = new Scanner(System.in);
    public static int VerificarInt(String x) {
        String variable = x;
        while (true){
            try {
                int numero = Integer.parseInt(variable);
                return numero;

            } catch (Exception e) {
                System.out.println("Error al ingresar la opcion, vuelva a ingresarla: ");variable=read.next();
            }
        }
    }
    public static boolean VerificacionSN(String x){
        while (true){
            try {
                if (x.toUpperCase().equals("N")){return false;}
                else if (x.toUpperCase().equals("S")){return true;}
                else {System.out.println("Opcion no valida, ingrese S/N");x=read.next();}

            } catch (Exception e) {
                System.out.println("Error al ingresar la opcion, vuelva a ingresarla: ");
            }
        }
    }
    void main() {
    }
}
