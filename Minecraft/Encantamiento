public class Encantamiento {
    private String nombre;
    private int id, nivel, nivelMax;

    public Encantamiento(int id, String nombre, int nivelMax) {
        this.id = id;
        this.nombre = nombre;
        this.nivel = 1;
        this.nivelMax = nivelMax;
    }

    public void SubirNivel() {
        if (nivel < nivelMax) nivel++;
    }

    public boolean EstaAlMax() { return nivel >= nivelMax; }

    public int getId() { return id; }
    public String getNombre() { return nombre; }
    public int getNivel() { return nivel; }
    public int getNivelMax() { return nivelMax; }
}
