import java.util.Scanner;

public class Main {

    static Scanner read = new Scanner(System.in);
    static Jugador Steve;

    public static void main(String[] args)
    {
        Menu();

    }
    public static void IngresarDatos()
    {
        if (Steve.getNombre().length()<1)
        {
            System.out.println("Antes de jugar Minecraft 2, ingrese su nombre de usuario");
            Steve.setNombre(read.next());
        }
    }
    public static void Menu()
    {
        IngresarDatos();
        do {
            System.out.println("\u001B[32m /// MINECRAFT 2 \\\\\\ por: ZARDLORD_");
            System.out.println();
        }while (true);
    }
}
