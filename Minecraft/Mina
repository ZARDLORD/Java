/*MINA:
Se podrá minar en diferentes profundidades cada una subiendo la dificultad y la rareza de los
materiales a obtener:

- Entre capa 60 a 40 no aparecen mobs pero solo aparece hierro y carbón (el carbón
aparece con un 20% de posibilidad, el hierro con un 5% y el lapis con 1%)

- Entre capa 40 y 15 hay un 10% de posiblididad de encontrarte con un mob (que te sacara
1 y 2 muslito) y empieza a aparecer redstone y oro (el carbón aparece con un 10%, el hierro
con un 10%, el lapis y redstone con un 5%, el oro con un 3%)

- Entre capa 15 y 5 hay un 15% de posibilidad de encontrarse con un mob (que te sacara
entre 2 y 3 muslitos) y aparece diamante y esmeralda (el hierro con un 10%, el lapis y redstone
con un 10%, el oro con un 5% y la esmeralda y diamante con un 3%)
 */

import java.util.Random;
import java.util.Scanner;

public class    Mina {
    static Scanner read = new Scanner(System.in);
    private int capa, dificultad,PorcentajeMobs;

    public Mina(){}
    public Mina(int capa) {
        this.capa = capa;
    }

    public int getCapa() {
        return capa;
    }
    public void setCapa(int capa) {
        this.capa = capa;
    }

    public float AparecerMob(Jugador jugador) {
        Random random = new Random();
        float muslitos = 0;

        // Calcular porcentaje real con armadura
        int porcentajeReal = PorcentajeMobs;
        Objeto_Armadura armadura = jugador.getInventario().BuscarArmadura();
        if (armadura != null) {
            porcentajeReal -= armadura.getReduccionMobs();
            if (porcentajeReal < 0) porcentajeReal = 0; // netherite lo deja en 0
        }

        int numero = random.nextInt(1, 101);
        if (numero <= porcentajeReal) {
            switch (dificultad) {
                case 2: muslitos = random.nextInt(1, 3); break;
                case 3: muslitos = random.nextInt(2, 4); break;
            }
            System.out.println("Un mob aparecio! Perdiste " + muslitos + " muslitos");
        }
        return muslitos;
    }
    private void AplicarRareza(Random random, int tirada, Jugador jugador) {
        Objeto mineral = null;
        int cantidad = 0;
        int exp = 0;

        switch (dificultad) {
            case 1:
                if (tirada <= 20) { mineral = Objeto.CARBON;    cantidad = random.nextInt(3,6); exp = 4; break; }
                if (tirada <= 25) { mineral = Objeto.MHIERRO;    cantidad = 1;                  exp = 0; break; }
                if (tirada <= 26) { mineral = Objeto.LAPIS;     cantidad = random.nextInt(4,7); exp = 6; break; }
                mineral = Objeto.PIEDRA; cantidad = random.nextInt(1,4); exp = 0; // siempre cae piedra si no salio nada
                break;
            case 2:
                if (tirada <= 10) { mineral = Objeto.CARBON;    cantidad = random.nextInt(3,6); exp = 4; break; }
                if (tirada <= 20) { mineral = Objeto.MHIERRO;    cantidad = 1;                  exp = 0; break; }
                if (tirada <= 25) { mineral = Objeto.LAPIS;     cantidad = random.nextInt(4,7); exp = 6; break; }
                if (tirada <= 30) { mineral = Objeto.REDSTONE;  cantidad = random.nextInt(4,7); exp = 6; break; }
                if (tirada <= 33) { mineral = Objeto.MORO;       cantidad = 1;                  exp = 0; break; }
                mineral = Objeto.PIEDRA; cantidad = random.nextInt(1,4); exp = 0;
                break;
            case 3:
                if (tirada <= 10) { mineral = Objeto.MHIERRO;    cantidad = 1;                  exp = 0; break; }
                if (tirada <= 20) { mineral = Objeto.LAPIS;     cantidad = random.nextInt(4,7); exp = 6; break; }
                if (tirada <= 30) { mineral = Objeto.REDSTONE;  cantidad = random.nextInt(4,7); exp = 6; break; }
                if (tirada <= 35) { mineral = Objeto.MORO;       cantidad = 1;                  exp = 0; break; }
                if (tirada <= 38) { mineral = Objeto.DIAMANTE;  cantidad = 1;                  exp = 8; break; }
                if (tirada <= 41) { mineral = Objeto.ESMERALDA; cantidad = 1;                  exp = 8; break; }
                mineral = Objeto.PIEDRA; cantidad = random.nextInt(1,4); exp = 0;
                break;
        }

        if (mineral != null) {
            Objeto_Herramienta pico = jugador.getInventario().BuscarHerramienta();
            if (pico != null && pico.PuedeRomper(mineral.getID())) {
                System.out.println("Encontraste: " + cantidad + "x " + mineral.getNombre());
                jugador.getInventario().AgregarItem(mineral, cantidad);
                jugador.setExperiencia(jugador.getExperiencia() + exp);
                if (exp > 0) System.out.println("+" + exp + " EXP");
            } else {
                System.out.println("Tu pico no puede romper " + mineral.getNombre());
            }
        } else {
            System.out.println("No encontraste nada...");
        }
    }
    public void Minar(Jugador jugador) {
        Objeto_Herramienta pico = jugador.getInventario().BuscarHerramienta();

        if (pico == null) {
            System.out.println("No tenes un pico para minar!");
            return;
        }

        Random random = new Random();
        int tirada = random.nextInt(1, 101);
        AplicarRareza(random, tirada, jugador);

        pico.Usar();
        System.out.println("Durabilidad del pico: " + pico.getUsosRestantes());

        if (pico.EstaRoto()) {
            System.out.println("Tu pico se rompio!");
            jugador.getInventario().EliminarItem(pico);
        }
    }
    public void ElegirCapa(int capa){
        do {
            try {
                if (capa>60 || capa<0){System.out.println("no hay minas a esta altura, seleccione otra capa");
                    capa= read.nextInt();}
                else {break;}
            }catch (Exception e){System.out.println("Error ingresando la capa, solo ingrese numeros");}
        }while (true);
        if (capa>=40 && capa<=60){dificultad=1;}
        if (capa>=15 && capa<40){dificultad=2;}
        if (capa>=5 && capa<15){dificultad=3;}
        switch (dificultad){
            case 1:PorcentajeMobs=0;break;
            case 2:PorcentajeMobs=10;break;
            case 3:PorcentajeMobs=15;break;
        }
    }
}
