    private static void AplicarEncantamiento(Objeto_Herramienta pico, Random random) {
        int tirada = random.nextInt(3);

        switch (tirada) {
            case 0: // Irrompibilidad (id=34, max nivel 3)
                int nivelAnterior = pico.getUsosTotales();
                pico.AgregarEncantamiento(new Encantamiento(34, "Irrompibilidad", 3));
                pico.AplicarIrrompibilidad();
                break;
            case 1: // Fortuna (id=35, max nivel 3)
                pico.AgregarEncantamiento(new Encantamiento(35, "Fortuna", 3));
                break;
            case 2: // Reparacion (id=70, max nivel 1)
                pico.AgregarEncantamiento(new Encantamiento(70, "Reparacion", 1));
                break;
        }
    }

    public static void IngresarDatos() {
        if (Steve.getNombre()==null|| Steve.getNombre().equals("Steve")) {
            System.out.println("Antes de jugar Minecraft 2, ingrese su nombre de usuario:");
            Steve.setNombre(read.next());
        }
    }

    public static void ExplorarMina(){
        System.out.println("Ingrese la capa de la mina que quiere explorar: ");
        int entrada=Util.VerificarInt(read.next());
        cueva.ElegirCapa(entrada);
        cueva.setCapa(entrada);
        do {
            Steve.Datos();
            System.out.println("Quieres minar? (S/N)");
            if (Util.VerificacionSN(read.next()))
            {
                Steve.setMuslitos(Steve.getMuslitos()-cueva.AparecerMob(Steve));
                if (Steve.getMuslitos()<=0){System.out.println("Te quedaste sin comida, abandona la mina");break;}
                cueva.Minar(Steve);}
            else {break;}
            FueACueva=true;
        }while (true);
    }

    public static void Cocinar() {
        do {
            System.out.println("Seleccione la mena que quiere cocinar (0 para salir):");
            // Mostrar solo las menas disponibles
            for (int i = 0; i < Steve.getInventario().getSize(); i++) {
                Objeto item = Steve.getInventario().getEspacios()[i];
                int cantidad = Steve.getInventario().getStacks()[i];
                System.out.println((i+1) + ") " + cantidad + "x " + item.getNombre());
            }

            int espacio = Util.VerificarInt(read.next()) - 1;
            if (espacio == -1) break;

            if (espacio >= Steve.getInventario().getSize()) {
                System.out.println("Este espacio no existe"); continue;
            }

            Objeto item = Steve.getInventario().getEspacios()[espacio];
            int IDitem = item.getID();

            if (IDitem != 14 && IDitem != 15) {
                System.out.println("Este item no es una mena"); continue;
            }

            int posCarbon = -1;
            for (int i = 0; i < Steve.getInventario().getSize(); i++) {
                if (Steve.getInventario().getEspacios()[i].getID() == 263) {
                    posCarbon = i; break;
                }
            }
            if (posCarbon == -1) { System.out.println("No tienes carbon"); continue; }

            int cantidadMena   = Steve.getInventario().getStacks()[espacio];
            int cantidadCarbon = Steve.getInventario().getStacks()[posCarbon];
            int maximoPorCarbon = cantidadCarbon * 8;
            int aCocinar = Math.min(cantidadMena, maximoPorCarbon);
            int carbonUsado = (int) Math.ceil(aCocinar / 8.0);

            Steve.getInventario().DescontarItem(IDitem, aCocinar);
            Steve.getInventario().DescontarItem(263, carbonUsado);

            Objeto mineralCocido = (IDitem == 15) ? Objeto.HIERRO : Objeto.ORO;
            Steve.getInventario().AgregarItem(mineralCocido, aCocinar);
            System.out.println("Cocinaste " + aCocinar + "x " + mineralCocido.getNombre()
                    + " usando " + carbonUsado + "x Carbon");

        } while (true);
    }
    public static void ExplorarAldea(){
        int opcion=0;
        do {
            System.out.println("Bienvenido a la aldea, selecciona el aldeano al que quieres ir, o la accion:"
                    +"\n1)Clerigo"
                    +"\n2)Comerciante"
                    +"\n3)Granjero"
                    +"\n4)Herrero de herramientas"
                    +"\n5)Herrero de armaduras"
                    +"\n6)Dormir"
                    +"\n7)Cocinar minerales"
                    +"\n8)Irse");
            opcion = Util.VerificarInt(read.next());
            switch (opcion){
                case 1:Aldeano.Clerigo(Steve);break;
                case 2:Aldeano.Comerciante(Steve);break;
                case 3:Aldeano.Granjero(Steve);break;
                case 4:Aldeano.HerreroHerramientas(Steve);break;
                case 5:Aldeano.HerreroArmaduras(Steve);break;
                case 6:Dormir();break;
                case 7:Cocinar();break;
