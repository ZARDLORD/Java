    public static void Dormir(){
        if (FueACueva){FueACueva=false;
        Steve.setMuslitos(Steve.getMuslitos()+2);
        System.out.println("Haz dormido, recuperaste 2.0 muslitos y ahora tienes "+Steve.getMuslitos() +" muslitos");}
        else {System.out.println("Para dormir, primero debes explorar una cueva");}
    }

    public static void AbrirInventario() {
        System.out.println("=== INVENTARIO ===");
        for (int i = 0; i < Steve.getInventario().getSize(); i++) {
            Objeto item = Steve.getInventario().getEspacios()[i];
            int cantidad = Steve.getInventario().getStacks()[i];

            if (item instanceof Objeto_Herramienta) {
                Objeto_Herramienta herramienta = (Objeto_Herramienta) item;
                System.out.print((i+1) + ") " + herramienta.getNombre()
                        + " (" + herramienta.getUsosRestantes()
                        + "/" + herramienta.getUsosTotales() + ")");
                // Encantamientos
                if (!herramienta.getEncantamientos().isEmpty()) {
                    System.out.print(" [");
                    for (Encantamiento e : herramienta.getEncantamientos()) {
                        System.out.print(e.getNombre() + " " + e.getNivel() + " ");
                    }
                    System.out.print("]");
                }
                System.out.println();
            } else {
                System.out.println((i+1) + ") " + cantidad + "x " + item.getNombre());
            }
        }

        System.out.println("Selecciona un item (0 para cerrar):");
        int seleccion = Util.VerificarInt(read.next()) - 1;

        if (seleccion == -1) return;

        if (seleccion >= Steve.getInventario().getSize()) {
            System.out.println("Espacio no existe"); return;
        }

        Objeto itemSeleccionado = Steve.getInventario().getEspacios()[seleccion];

        if (itemSeleccionado instanceof Objeto_Comida) {
            Objeto_Comida comida = (Objeto_Comida) itemSeleccionado;
            System.out.println("Quieres comer " + comida.getNombre() + "? (S/N)");
            if (Util.VerificacionSN(read.next())) {
                Comer(comida);
            }
        } else if (itemSeleccionado.getID() == 14 || itemSeleccionado.getID() == 15) {
            System.out.println("Quieres cocinar " + itemSeleccionado.getNombre() + "? (S/N)");
            if (Util.VerificacionSN(read.next())) {
                Cocinar();
            }
        } else {
            System.out.println(itemSeleccionado.getNombre() + " no tiene ninguna accion disponible");
        }
    }
    public static void Comer(Objeto_Comida comida) {
        float nuevosMuslitos = Steve.getMuslitos() + comida.getMuslitosQueRecupera();
        Steve.setMuslitos(Math.min(nuevosMuslitos, 10.0f));
        Steve.getInventario().DescontarItem(comida.getID(), 1);
        System.out.println("Comiste " + comida.getNombre()
                + ", muslitos: " + Steve.getMuslitos());
    }

    public static void Encantar() {
        Objeto_Herramienta pico = Steve.getInventario().BuscarHerramienta();

        if (pico == null) {
            System.out.println("No tienes un pico para encantar"); return;
        }

        int nivel = Steve.getNivel();
        System.out.println("Pico: " + pico.getNombre());
        System.out.println("Nivel actual: " + nivel + " (EXP: " + Steve.getExperiencia() + ")");

        if (nivel < 10) {
            System.out.println("Necesitas al menos nivel 10 para encantar"); return;
        }

        System.out.println("Cuantos niveles quieres gastar? (10-30, 0 para cancelar)");
        int nivelesAGastar = Util.VerificarInt(read.next());

        if (nivelesAGastar == 0) return;

        if (nivelesAGastar < 10 || nivelesAGastar > 30) {
            System.out.println("Debes gastar entre 10 y 30 niveles"); return;
        }
        if (nivelesAGastar > nivel) {
            System.out.println("No tienes suficientes niveles (tenes " + nivel + ")"); return;
        }

        Steve.GastarNiveles(nivelesAGastar);
        Random random = new Random();

        // Con 30+ niveles hay chance de obtener 2 encantamientos
        int cantidadEncantamientos = 1;
        if (nivelesAGastar >= 30 && random.nextInt(100) < 50) {
            cantidadEncantamientos = 2;
            System.out.println("Encantamiento poderoso! Puedes obtener hasta 2 encantamientos");
        }

        System.out.println("Encantando " + pico.getNombre() + "...");
        for (int i = 0; i < cantidadEncantamientos; i++) {
            AplicarEncantamiento(pico, random);
        }

        // Mostrar encantamientos actuales del pico
        if (!pico.getEncantamientos().isEmpty()) {
            System.out.print("Encantamientos: ");
            for (Encantamiento e : pico.getEncantamientos()) {
                System.out.print(e.getNombre() + " " + e.getNivel() + "  ");
            }
            System.out.println();
        }
    }
