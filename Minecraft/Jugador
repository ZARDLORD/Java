public class Main {

    static Scanner read = new Scanner(System.in);
    static Inventario inv = new Inventario();
    static Mina cueva = new Mina();
    static boolean FueACueva = false;
    static Jugador Steve = new Jugador("A001","Steve",0,10f,inv);

    public static void main(String[] args) {
        Menu();

