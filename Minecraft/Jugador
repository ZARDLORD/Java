            System.out.println("3) Abrir inventario");
            System.out.println("4) Encantar pico");
            System.out.println("5) Salir");
            opcionmenu = Util.VerificarInt(read.next());
            switch (opcionmenu){
                case 1:ExplorarMina();break;
                case 2:ExplorarAldea();break;
                case 3:AbrirInventario();break;
                case 4:Encantar();break;
                default:System.out.println("Error al ingresar la opcion, vuelva a ingresar");break;
            }
        } while (opcionmenu!=5);
    }
}
