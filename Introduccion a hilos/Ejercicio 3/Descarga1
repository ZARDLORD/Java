import java.util.Random;

public class Descarga1 extends Thread{
    public Descarga1(){
        System.out.println("Descarga1 iniciada.");
    }
    public static Random random = new Random();
    int porcentaje=0;
    public void run(){
        while (true){
        try {
            if (porcentaje>=100){System.out.println("Descarga finalizada en D1");break;}
            else {
            porcentaje+=random.nextInt(10);
            System.out.println("D1 Porcentaje: "+porcentaje);
            Descarga1.sleep(300);}
        }catch (Exception e){System.out.println("Error: " +e);}

    }}
}
