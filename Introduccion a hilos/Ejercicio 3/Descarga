public class Descarga extends HiloUtil{
    int numero;
    public Descarga(int numero){
        this.numero=numero;
        System.out.println("Descarga "+numero+" iniciada");
    }
    int porcentaje=0;
    @Override
    public void run()
    {
        while (true){
            try {
                if (porcentaje>=100 && Main.verificacion==0){Main.verificacion=numero;break;}
                else {
                    if (Main.verificacion==0){
                    System.out.println("D"+numero+" Porcentaje: "+porcentaje);
                    porcentaje+=NumeroRandom();
                    Thread.sleep(300);}else {break;}}
            }catch (Exception e){System.out.println("Error: " +e);}

        }
    }
}
