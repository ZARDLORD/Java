public class Main{

    public static int verificacion=0;
    public static void main(String[] args) {
        Thread d1 = new Thread(new Descarga(1));
        Thread d2 = new Thread(new Descarga(2));
        Thread d3 = new Thread(new Descarga(3));
        while (verificacion!=0){
            d1.start();
            d2.start();
            d3.start();
        }
    }
}
