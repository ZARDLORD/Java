public class Personaje extends HiloUtil{
    int numero;
    String nombre;
    public Personaje(int numero, String nombre){
        this.numero=numero;
        this.nombre=nombre;
        System.out.println("Descarga "+numero+" iniciada");
    }
    int porcentaje=0;
    @Override
    public void run()
    {
        while (true){
            try {
                if (porcentaje>=100 && Main.verificacion==0)
                {
                    Main.verificacion=numero;
                    break;
                }
                else {
                    if (Main.verificacion==0){
                    System.out.println(nombre+": "+" metros: "+porcentaje);
                    porcentaje+=NumeroRandom();
                    Thread.sleep(300);}else {break;}}
            }catch (Exception e){System.out.println("Error: " +e);}

        }
    }
}
